<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Welcome to Error Code AI</title>
    <!--Google Font-->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />

  </head>

  <body style="margin:0; padding:0; background-color:#f5f5f5;">
    <!-- FULL WIDTH WRAPPER -->
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      bgcolor="#f5f5f5"
      style="font-family:'Poppins', Arial, Helvetica, sans-serif; font-weight: 400;"
    >
      <tr>
        <td align="center" style="padding:40px 16px;">

          <!-- CARD CONTAINER -->
          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            bgcolor="#ffffff"
            style="border-top:4px solid #2563eb; border-radius:6px;"
          >

            <!-- HEADER -->
            <tr>
              <td style="padding:32px 32px 16px 32px;">
                <table cellpadding="0" cellspacing="0">
                  <tr>
                    <td
                      width="42"
                      height="42"
                      align="center"
                      valign="middle"
                      style="
                        background:#2563eb;
                        color:#ffffff;
                        font-weight:bold;
                        font-size:16px;
                        border-radius:50%;
                        font-family:Arial, Helvetica, sans-serif;
                      "
                    >
                      EC
                    </td>
                    <td style="padding-left:12px;">
                      <h1
                        style="
                          margin:0;
                          font-size:22px;
                          color:#1f2937;
                          font-family:Arial, Helvetica, sans-serif;
                        "
                      >
                        Error Code - AI
                      </h1>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- WELCOME CONTENT -->
            <tr>
              <td style="padding:0 32px 24px 32px;">
                <h2
                  style="
                    margin:0 0 12px 0;
                    font-size:20px;
                    color:#1f2937;
                    font-family:Arial, Helvetica, sans-serif;
                  "
                >
                  Welcome to your coding journey
                </h2>

                <p
                  style="
                    margin:0;
                    font-size:14px;
                    color:#4b5563;
                    line-height:1.6;
                    font-family:Arial, Helvetica, sans-serif;
                  "
                >
                  We’re excited to have you onboard! Your account has been
                  successfully created on
                  <strong>Error Code - AI</strong>, your hands-on coding
                  practice platform.
                </p>
              </td>
            </tr>

            <!-- CREDENTIALS BOX -->
            <tr>
              <td style="padding:0 32px 24px 32px;">
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  bgcolor="#f9fafb"
                  style="border-radius:4px;"
                >
                  <tr>
                    <td
                      style="
                        padding:20px;
                        font-family:Arial, Helvetica, sans-serif;
                      "
                    >
                      <h3
                        style="
                          margin:0 0 12px 0;
                          font-size:16px;
                          color:#1f2937;
                        "
                      >
                        Your Login Credentials
                      </h3>

                      <p style="margin:0 0 8px 0; font-size:14px;">
                        <strong>Username:</strong>
                        {{name}}
                      </p>

                      <p style="margin:0 0 8px 0; font-size:14px;">
                        <strong>Email:</strong>
                        {{email}}
                      </p>

                      <p style="margin:0 0 8px 0; font-size:14px;">
                        <strong>Password:</strong>
                        {{password}}
                      </p>

                      <p
                        style="
                          margin-top:12px;
                          font-size:12px;
                          color:#6b7280;
                        "
                      >
                        For security reasons, please change your password after
                        logging in.
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- CTA BUTTON -->
            <tr>
              <td align="center" style="padding-bottom:32px;">
                <a
                  href="{{login_link}}"
                  style="
                    background:#2563eb;
                    color:#ffffff;
                    text-decoration:none;
                    padding:14px 28px;
                    border-radius:6px;
                    font-size:15px;
                    font-weight:bold;
                    font-family:Arial, Helvetica, sans-serif;
                    display:inline-block;
                  "
                >
                  Start Coding
                </a>
              </td>
            </tr>

            <!-- FOOTER -->
            <tr>
              <td
                style="
                  padding:16px 32px;
                  border-top:1px solid #d1d5db;
                  text-align:center;
                  font-family:Arial, Helvetica, sans-serif;
                "
              >
                <p
                  style="
                    margin:0 0 8px 0;
                    font-size:12px;
                    color:#6b7280;
                  "
                >
                  If you face any issues while logging in, feel free to reach
                  out to our support team.
                </p>

                <p style="margin:0 0 8px 0; font-size:12px;">
                  Happy Coding! 💙<br />
                  <strong>Team Error Code - AI</strong>
                </p>

                <p
                  style="
                    margin:0;
                    font-size:11px;
                    color:#9ca3af;
                  "
                >
                  ©
                  {{year}}
                  Error Code - AI. All rights reserved.
                </p>
              </td>
            </tr>

          </table>
          <!-- END CARD -->

        </td>
      </tr>
    </table>
    <!-- END WRAPPER -->
  </body>
</html>